      "source": [
        "#to check the number is prime or not\n",
        "num = int(input(\"Enter number\"))\n",
        "count=0\n",
        "for i in range(1,num+1):\n",
        "  if(num%i==0):\n",
        "    count+=1\n",
        "if(count==2):\n",
        "  print(\"its a prime number\")\n",
        "else:\n",
        "  print(\"not a prime\")\n"
      ]
